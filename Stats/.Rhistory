Normal.CI= function(x,lev=0.95,sigma=1){
alpha= 1-lev
z= qnorm(1-alpha/2) #normal quantile
xbar= mean(x)# sample mean
n= length(x) #sample size
MoE= z*sigma/sqrt(n) # margin of error
L1= xbar - MoE
L2 = xbar + MoE
CI= c(L1,L2) #interval
return CI
Normal.CI= function(x,lev=0.95,sigma=1){
alpha= 1-lev
z= qnorm(1-alpha/2) #normal quantile
xbar= mean(x)# sample mean
n= length(x) #sample size
MoE= z*sigma/sqrt(n) # margin of error
L1= xbar - MoE
L2 = xbar + MoE
CI= c(L1,L2) #interval
return CI
#Example
x= rnorm(30, 2, 1)
CI1= Normal.CI(x,0.95,1)
return (CI)
Normal.CI= function(x,lev=0.95,sigma=1){
alpha= 1-lev
z= qnorm(1-alpha/2) #normal quantile
xbar= mean(x)# sample mean
n= length(x) #sample size
MoE= z*sigma/sqrt(n) # margin of error
L1= xbar - MoE
L2 = xbar + MoE
CI= c(L1,L2) #interval
return (CI)
}
#Example
x= rnorm(30, 2, 1)
CI1= Normal.CI(x,0.95,1)
CI1
diff(CI1)
#if we increase conf levl at 99%
CI2= Normal.CI(x,0.99)
CI2
diff(CI2)
